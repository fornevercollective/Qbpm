  "qbpmIntegration": {
    "current": {
      "audio": "Web Audio oscillator (playTone in piano-app.js)",
      "midi": "catalog.js + songs.js beat/midi events",
      "strudel": "strudel-pane.js + strudel-samples.js"
    },
    "recommendedStack": [
      {
        "role": "piano playback",
        "choice": "dough-piano (Salamander) via Strudel samples OR WebAudioFont GM program 0",
        "why": "Matches Strudel ecosystem; Salamander is the Strudel default piano timbre"
      },
      {
        "role": "organ playback",
        "choice": "Strudel gm_church_organ / gm_drawbar_organ OR VCSL Keys pipe organ samples",
        "why": "Full GM organ family (16–23) without shipping large sample banks"
      },
      {
        "role": "MIDI import",
        "choice": "GiantMIDI-Piano + piano-midi.de + built-in catalog.js",
        "why": "Open licenses; convert .mid → {midi, beat, duration} for piano roll"
      }
    ],
    "strudelLoadSnippet": "const ds = 'https://raw.githubusercontent.com/felixroos/dough-samples/main/';\nawait samples(`${ds}piano.json`);\n// piano: n('c4 e4 g4').sound('piano')\n// organ: n('c3').sound('gm_church_organ')",
    "webaudiofontSnippet": "import { WebAudioFontPlayer } from 'webaudiofont';\nconst player = new WebAudioFontPlayer();\n// preset URLs: surikov.github.io/webaudiofontdata/sound/FluidR3_GM/0000_FluidR3_GM_sf2_file.js"
  }
}